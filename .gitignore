# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# the merged build IS committed (dist/index.html) so GitHub Pages + downloads work with no build step.
# src/lib/vendor.js (CodeMirror 6 + luaparse) is ALSO committed -- regenerate with tools/vendor.

# the vendoring toolchain's local state (only needed to REgenerate src/lib/vendor.js)
tools/vendor/node_modules/
tools/vendor/package-lock.json

# python bytecode from tools/
__pycache__/
*.pyc

# per-endpoint benchmark splits (merged into bench-tools-results.json)
bench-local.json
bench-deepseek.json
bench-openrouter.json

# reasoning-bench working files (backups / shakeout / snapshots) -- the live result is
# bench-reason-results.json; these are transient
bench-reason-results.bak*.json
bench-reason-shakeout.json
bench-reason-snapshot.json

# generated dashboards (regenerate with tools/bench_viz.py; may embed one-off hosted data)
bench-viz.html
bench-viz-test.html
